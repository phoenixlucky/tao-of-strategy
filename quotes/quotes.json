  "quotes": [
    {"id":"sunzi-1","person":"sunzi","text":"兵者，诡道也。故能而示之不能，用而示之不用","source":"《孙子兵法·始计篇》","tags":["进取","诡道","权变"],"face":"进取"},
    {"id":"sunzi-2","person":"sunzi","text":"知彼知己，百战不殆","source":"《孙子兵法·谋攻篇》","tags":["进取","庙算","用间"],"face":"进取"},
    {"id":"sunzi-3","person":"sunzi","text":"不战而屈人之兵，善之善者也","source":"《孙子兵法·谋攻篇》","tags":["转化","全胜","不争"],"face":"转化"},
    {"id":"sunzi-4","person":"sunzi","text":"攻其无备，出其不意","source":"《孙子兵法·始计篇》","tags":["进取","速决","诡道"],"face":"进取"},
    {"id":"sunzi-5","person":"sunzi","text":"夫兵形象水，水之形避高而趋下，兵之形避实而击虚","source":"《孙子兵法·虚实篇》","tags":["转化","形势","守柔"],"face":"转化"},
    {"id":"sunzi-6","person":"sunzi","text":"善战者之胜也，无智名，无勇功","source":"《孙子兵法·军形篇》","tags":["转化","全胜","无为","大智若愚"],"face":"转化"},
    {"id":"sunzi-7","person":"sunzi","text":"投之亡地然后存，陷之死地然后生","source":"《孙子兵法·九地篇》","tags":["转化","阴阳相生","形势"],"face":"转化"},
    {"id":"sunzi-8","person":"sunzi","text":"主不可以怒而兴师，将不可以愠而致战","source":"《孙子兵法·火攻篇》","tags":["避世","修身","无为"],"face":"避世"},
    {"id":"sunzi-9","person":"sunzi","text":"先为不可胜，以待敌之可胜","source":"《孙子兵法·军形篇》","tags":["转化","庙算","无为"],"face":"转化"},
    {"id":"sunzi-10","person":"sunzi","text":"善用兵者，修道而保法","source":"《孙子兵法·军形篇》","tags":["进取","庙算","治国"],"face":"进取"},

    {"id":"wuzi-1","person":"wuzi","text":"内修文德，外治武备","source":"《吴子·图国篇》","tags":["进取","治国","庙算"],"face":"进取"},
    {"id":"wuzi-2","person":"wuzi","text":"不和于国，不可以出军","source":"《吴子·图国篇》","tags":["进取","形势","修身"],"face":"进取"},
    {"id":"wuzi-3","person":"wuzi","text":"用兵之法，教戒为先","source":"《吴子·治兵篇》","tags":["进取","庙算","全胜"],"face":"进取"},
    {"id":"wuzi-4","person":"wuzi","text":"以近待远，以逸待劳，以饱待饥","source":"《吴子·治兵篇》","tags":["进取","形势","速决"],"face":"进取"},
    {"id":"wuzi-5","person":"wuzi","text":"进死为荣，退生为辱","source":"《吴子·图国篇》","tags":["进取","修身"],"face":"进取"},
    {"id":"wuzi-6","person":"wuzi","text":"凡战者，以形胜","source":"《吴子·料敌篇》","tags":["进取","形势","庙算"],"face":"进取"},
    {"id":"wuzi-7","person":"wuzi","text":"用兵之害，犹豫最大","source":"《吴子·治兵篇》","tags":["进取","速决","修身"],"face":"进取"},
    {"id":"wuzi-8","person":"wuzi","text":"总文武者，军之将也；兼刚柔者，兵之事也","source":"《吴子·论将篇》","tags":["转化","修身","权变"],"face":"转化"},
    {"id":"wuzi-9","person":"wuzi","text":"居则有礼，动则有威","source":"《吴子·论将篇》","tags":["进取","形势"],"face":"进取"},
    {"id":"wuzi-10","person":"wuzi","text":"进有重赏，退有重刑，行之以信","source":"《吴子·治兵篇》","tags":["进取","治国"],"face":"进取"},

    {"id":"sunbin-1","person":"sunbin","text":"围魏救赵——批亢捣虚，形格势禁","source":"《史记》引孙膑；《孙膑兵法》","tags":["进取","奇正","诡道"],"face":"进取"},
    {"id":"sunbin-2","person":"sunbin","text":"避实击虚，以众击寡","source":"《孙膑兵法·威王问》","tags":["进取","形势","诡道"],"face":"进取"},
    {"id":"sunbin-3","person":"sunbin","text":"间于天地之间，莫贵于人","source":"《孙膑兵法·月战》","tags":["转化","修身","无为"],"face":"转化"},
    {"id":"sunbin-4","person":"sunbin","text":"战胜而强立，故天下服矣","source":"《孙膑兵法·见威王》","tags":["进取","庙算","全胜"],"face":"进取"},
    {"id":"sunbin-5","person":"sunbin","text":"无形而制形，奇也","source":"《孙膑兵法·奇正篇》","tags":["转化","奇正","玄同"],"face":"转化"},
    {"id":"sunbin-6","person":"sunbin","text":"胜不可一也","source":"《孙膑兵法·奇正篇》","tags":["进取","奇正","权变"],"face":"进取"},
    {"id":"sunbin-7","person":"sunbin","text":"见敌之所长，则知其所短","source":"《孙膑兵法·奇正篇》","tags":["转化","形势","阴阳相生"],"face":"转化"},
    {"id":"sunbin-8","person":"sunbin","text":"兵者，非士恒势也","source":"《孙膑兵法·威王问》","tags":["进取","形势","无为"],"face":"进取"},
    {"id":"sunbin-9","person":"sunbin","text":"战者，以形相胜者也","source":"《孙膑兵法·奇正篇》","tags":["进取","形势","庙算"],"face":"进取"},
    {"id":"sunbin-10","person":"sunbin","text":"天地之理，至则反，盈则败","source":"《孙膑兵法·奇正篇》","tags":["转化","阴阳相生","归根"],"face":"转化"},

    {"id":"weiliao-1","person":"weiliao","text":"兵胜于朝廷","source":"《尉缭子·兵令上》","tags":["进取","庙算","治国"],"face":"进取"},
    {"id":"weiliao-2","person":"weiliao","text":"天时不如地利，地利不如人和","source":"《尉缭子·战威篇》","tags":["转化","修身","治国"],"face":"转化"},
    {"id":"weiliao-3","person":"weiliao","text":"杀一人而三军震者，杀之；赏一人而万人悦者，赏之","source":"《尉缭子·武议篇》","tags":["进取","治国"],"face":"进取"},
    {"id":"weiliao-4","person":"weiliao","text":"凡挟义而战者，贵从我起","source":"《尉缭子·攻权篇》","tags":["进取","奇正","权变"],"face":"进取"},
    {"id":"weiliao-5","person":"weiliao","text":"举贤用能，不时日而事利","source":"《尉缭子·战威篇》","tags":["避世","治国","无为"],"face":"避世"},
    {"id":"weiliao-6","person":"weiliao","text":"夫将者，士之心也；士者，将之体也","source":"《尉缭子·攻权篇》","tags":["进取","修身","治国"],"face":"进取"},
    {"id":"weiliao-7","person":"weiliao","text":"器用不备，不可以战","source":"《尉缭子·武议篇》","tags":["进取","庙算"],"face":"进取"},
    {"id":"weiliao-8","person":"weiliao","text":"凡诛者，所以明武也","source":"《尉缭子·武议篇》","tags":["进取","治国","权变"],"face":"进取"},
    {"id":"weiliao-9","person":"weiliao","text":"战胜于外，备主于内","source":"《尉缭子·兵令上》","tags":["转化","庙算","归根"],"face":"转化"},
    {"id":"weiliao-10","person":"weiliao","text":"反本者富，滞末者贫","source":"《尉缭子·治本篇》","tags":["转化","归根","治国"],"face":"转化"},

    {"id":"caocao-1","person":"caocao","text":"观兵书战策多矣，孙武所著深矣","source":"曹操《孙子兵法序》","tags":["进取","庙算"],"face":"进取"},
    {"id":"caocao-2","person":"caocao","text":"宁我负人，毋人负我","source":"《三国志》引注","tags":["进取","权变"],"face":"进取"},
    {"id":"caocao-3","person":"caocao","text":"白骨露于野，千里无鸡鸣","source":"曹操《蒿里行》","tags":["避世","修身"],"face":"避世"},
    {"id":"caocao-4","person":"caocao","text":"月明星稀，乌鹊南飞","source":"曹操《短歌行》","tags":["避世","修身"],"face":"避世"},
    {"id":"caocao-5","person":"caocao","text":"对酒当歌，人生几何","source":"曹操《短歌行》","tags":["转化","修身","逍遥"],"face":"转化"},
    {"id":"caocao-6","person":"caocao","text":"老骥伏枥，志在千里","source":"曹操《龟虽寿》","tags":["进取","修身"],"face":"进取"},
    {"id":"caocao-7","person":"caocao","text":"山不厌高，海不厌深。周公吐哺，天下归心","source":"曹操《短歌行》","tags":["进取","治国"],"face":"进取"},
    {"id":"caocao-8","person":"caocao","text":"设使国家无有孤，不知当几人称帝，几人称王","source":"曹操《让县自明本志令》","tags":["进取","权变"],"face":"进取"},
    {"id":"caocao-9","person":"caocao","text":"神龟虽寿，犹有竟时","source":"曹操《龟虽寿》","tags":["转化","归根","修身"],"face":"转化"},
    {"id":"caocao-10","person":"caocao","text":"月明星稀，乌鹊南飞。绕树三匝，何枝可依","source":"曹操《短歌行》","tags":["避世","修身","权变"],"face":"避世"},

    {"id":"lijing-1","person":"lijing","text":"奇正相生，如循环之无端","source":"《唐太宗李卫公问对·卷上》","tags":["转化","奇正","玄同"],"face":"转化"},
    {"id":"lijing-2","person":"lijing","text":"攻是守之机，守是攻之策","source":"《唐太宗李卫公问对·卷下》","tags":["转化","阴阳相生","形势"],"face":"转化"},
    {"id":"lijing-3","person":"lijing","text":"千章万句，不出乎致人而不致于人而已","source":"《唐太宗李卫公问对·卷中》","tags":["进取","奇正","无为"],"face":"进取"},
    {"id":"lijing-4","person":"lijing","text":"但教正兵耳，奇亦何法也","source":"《唐太宗李卫公问对·卷上》","tags":["进取","奇正","无为"],"face":"进取"},
    {"id":"lijing-5","person":"lijing","text":"阵法者，所以临敌制变也","source":"《唐太宗李卫公问对·卷中》","tags":["进取","形势","权变"],"face":"进取"},
    {"id":"lijing-6","person":"lijing","text":"不战而屈人之兵者，上也；百战百胜者，中也","source":"《唐太宗李卫公问对·卷下》","tags":["进取","全胜","不争"],"face":"进取"},
    {"id":"lijing-7","person":"lijing","text":"奇正之术，分合为变","source":"《唐太宗李卫公问对·卷上》","tags":["进取","奇正","阴阳相生"],"face":"进取"},
    {"id":"lijing-8","person":"lijing","text":"善用兵者，无不正，无不奇","source":"《唐太宗李卫公问对·卷上》","tags":["转化","奇正","玄同"],"face":"转化"},
    {"id":"lijing-9","person":"lijing","text":"教得其道，则士乐为用","source":"《唐太宗李卫公问对·卷上》","tags":["转化","修身","无为"],"face":"转化"},
    {"id":"lijing-10","person":"lijing","text":"以诱待来，以静待躁","source":"《唐太宗李卫公问对·卷中》","tags":["转化","形势","无为"],"face":"转化"},

    {"id":"hanxin-1","person":"hanxin","text":"明修栈道，暗度陈仓","source":"《史记·淮阴侯列传》","tags":["进取","奇正","诡道"],"face":"进取"},
    {"id":"hanxin-2","person":"hanxin","text":"背水陈——陷之死地而后生","source":"《史记·淮阴侯列传》","tags":["进取","形势","阴阳相生"],"face":"进取"},
    {"id":"hanxin-3","person":"hanxin","text":"臣多多而益善耳","source":"《史记·淮阴侯列传》","tags":["进取","任势","无为"],"face":"进取"},
    {"id":"hanxin-4","person":"hanxin","text":"陷之死地而后生，置之亡地而后存","source":"《史记·淮阴侯列传》引兵法","tags":["转化","形势","阴阳相生"],"face":"转化"},
    {"id":"hanxin-5","person":"hanxin","text":"千金一饭——赐漂母千金","source":"《史记·淮阴侯列传》","tags":["转化","修身"],"face":"转化"},
    {"id":"hanxin-6","person":"hanxin","text":"胯下之辱——孰视之，俛出袴下","source":"《史记·淮阴侯列传》","tags":["转化","守柔","大智若愚"],"face":"转化"},
    {"id":"hanxin-7","person":"hanxin","text":"驱市人而战","source":"《史记·淮阴侯列传》","tags":["进取","任势","无为"],"face":"进取"},
    {"id":"hanxin-8","person":"hanxin","text":"知汉王畏恶其能，常称病不朝从","source":"《史记·淮阴侯列传》","tags":["避世","功成身退","修身"],"face":"避世"},
    {"id":"hanxin-9","person":"hanxin","text":"攻其所不守","source":"《史记·淮阴侯列传》","tags":["进取","奇正","形势"],"face":"进取"},
    {"id":"hanxin-10","person":"hanxin","text":"成也萧何，败也萧何","source":"民间谚语·《史记》故事","tags":["转化","归根","阴阳相生"],"face":"转化"},

    {"id":"simarangju-1","person":"simarangju","text":"以仁为本，以义治之","source":"《司马法·仁本》","tags":["进取","修身","治国"],"face":"进取"},
    {"id":"simarangju-2","person":"simarangju","text":"入罪人之地，无暴神祇","source":"《司马法·仁本》","tags":["避世","全胜","不争"],"face":"避世"},
    {"id":"simarangju-3","person":"simarangju","text":"国虽大，好战必亡；天下虽安，忘战必危","source":"《司马法·仁本》","tags":["转化","庙算","不争"],"face":"转化"},
    {"id":"simarangju-4","person":"simarangju","text":"杀人安人，杀之可也；以战止战，战之可也","source":"《司马法·仁本》","tags":["转化","全胜","修身"],"face":"转化"},
    {"id":"simarangju-5","person":"simarangju","text":"凡战，以力久，以气胜","source":"《司马法·严位》","tags":["进取","形势","修身"],"face":"进取"},
    {"id":"simarangju-6","person":"simarangju","text":"用寡固，用众治","source":"《司马法·用众》","tags":["进取","形势","权变"],"face":"进取"},
    {"id":"simarangju-7","person":"simarangju","text":"兵者，诡道也。诡者，所以乘其变也","source":"《司马法》残简","tags":["进取","诡道","任势"],"face":"进取"},
    {"id":"simarangju-8","person":"simarangju","text":"大小坚柔，参伍而用","source":"《司马法·定爵》","tags":["转化","阴阳相生","形势"],"face":"转化"},
    {"id":"simarangju-9","person":"simarangju","text":"凡战，智也；斗，勇也；阵，巧也","source":"《司马法·定爵》","tags":["进取","庙算","修身"],"face":"进取"},
    {"id":"simarangju-10","person":"simarangju","text":"位欲严，政欲栗，气欲闲","source":"《司马法·严位》","tags":["转化","修身","无为"],"face":"转化"},

    {"id":"laozi-1","person":"laozi","text":"反者道之动，弱者道之用","source":"《道德经》第四十章","tags":["避世","归根","阴阳相生"],"face":"避世"},
    {"id":"laozi-2","person":"laozi","text":"上善若水。水善利万物而不争","source":"《道德经》第八章","tags":["避世","不争","守柔"],"face":"避世"},
    {"id":"laozi-3","person":"laozi","text":"将欲歙之，必固张之。是谓微明","source":"《道德经》第三十六章","tags":["转化","阴阳相生","诡道"],"face":"转化"},
    {"id":"laozi-4","person":"laozi","text":"道常无为而无不为","source":"《道德经》第三十七章","tags":["避世","无为","归根"],"face":"避世"},
    {"id":"laozi-5","person":"laozi","text":"知足不辱，知止不殆，可以长久","source":"《道德经》第四十四章","tags":["避世","知足","归根"],"face":"避世"},
    {"id":"laozi-6","person":"laozi","text":"以正治国，以奇用兵，以无事取天下","source":"《道德经》第五十七章","tags":["转化","无为","奇正"],"face":"转化"},
    {"id":"laozi-7","person":"laozi","text":"兵者不祥之器，非君子之器，不得已而用之","source":"《道德经》第三十一章","tags":["避世","无为","不争"],"face":"避世"},
    {"id":"laozi-8","person":"laozi","text":"大直若屈，大巧若拙，大辩若讷","source":"《道德经》第四十五章","tags":["转化","大智若愚","诡道"],"face":"转化"},
    {"id":"laozi-9","person":"laozi","text":"祸兮福之所倚，福兮祸之所伏","source":"《道德经》第五十八章","tags":["转化","归根","阴阳相生"],"face":"转化"},
    {"id":"laozi-10","person":"laozi","text":"天下难事必作于易，天下大事必作于细","source":"《道德经》第六十三章","tags":["转化","无为","庙算"],"face":"转化"},

    {"id":"zhuangzi-1","person":"zhuangzi","text":"人皆知有用之用，而莫知无用之用也","source":"《庄子·人间世》","tags":["转化","大智若愚","不争"],"face":"转化"},
    {"id":"zhuangzi-2","person":"zhuangzi","text":"以无厚入有间，恢恢乎其于游刃必有余地","source":"《庄子·养生主》","tags":["转化","守柔","形势"],"face":"转化"},
    {"id":"zhuangzi-3","person":"zhuangzi","text":"北冥有鱼，其名为鲲。化而为鸟，其名为鹏","source":"《庄子·逍遥游》","tags":["避世","逍遥","归根"],"face":"避世"},
    {"id":"zhuangzi-4","person":"zhuangzi","text":"吾生也有涯，而知也无涯。以有涯随无涯，殆已","source":"《庄子·养生主》","tags":["避世","知足","修身"],"face":"避世"},
    {"id":"zhuangzi-5","person":"zhuangzi","text":"天地与我并生，而万物与我为一","source":"《庄子·齐物论》","tags":["避世","归根","玄同"],"face":"避世"},
    {"id":"zhuangzi-6","person":"zhuangzi","text":"子非鱼，安知鱼之乐","source":"《庄子·秋水》","tags":["避世","无为","修身"],"face":"避世"},
    {"id":"zhuangzi-7","person":"zhuangzi","text":"至人无己，神人无功，圣人无名","source":"《庄子·逍遥游》","tags":["转化","无为","大智若愚"],"face":"转化"},
    {"id":"zhuangzi-8","person":"zhuangzi","text":"鹏之徙于南冥也，水击三千里，抟扶摇而上者九万里","source":"《庄子·逍遥游》","tags":["避世","逍遥","任势"],"face":"避世"},
    {"id":"zhuangzi-9","person":"zhuangzi","text":"相濡以沫，不如相忘于江湖","source":"《庄子·大宗师》","tags":["避世","逍遥","不争"],"face":"避世"},
    {"id":"zhuangzi-10","person":"zhuangzi","text":"人生天地之间，若白驹之过隙，忽然而已","source":"《庄子·知北游》","tags":["转化","归根","修身"],"face":"转化"},

    {"id":"liezi-1","person":"liezi","text":"虽我之死，有子存焉；子子孙孙无穷匮也，而山不加增","source":"《列子·汤问》（愚公移山）","tags":["转化","修身","归根"],"face":"转化"},
    {"id":"liezi-2","person":"liezi","text":"杞国有人忧天地崩坠","source":"《列子·天瑞》（杞人忧天）","tags":["避世","无为","修身"],"face":"避世"},
    {"id":"liezi-3","person":"liezi","text":"朝三而暮四，众狙皆怒；朝四而暮三，众狙皆喜","source":"《列子·黄帝》（朝三暮四）","tags":["转化","诡道","无为"],"face":"转化"},
    {"id":"liezi-4","person":"liezi","text":"天下有常胜之道曰柔，常不胜之道曰强","source":"《列子·黄帝》","tags":["转化","守柔","不争"],"face":"转化"},
    {"id":"liezi-5","person":"liezi","text":"生无所息","source":"《列子·天瑞》","tags":["转化","修身","逍遥"],"face":"转化"},
    {"id":"liezi-6","person":"liezi","text":"得时者昌，失时者亡","source":"《列子·说符》","tags":["转化","任势","归根"],"face":"转化"},
    {"id":"liezi-7","person":"liezi","text":"凡顺天时，不违天时","source":"《列子·汤问》","tags":["避世","无为","任势"],"face":"避世"},
    {"id":"liezi-8","person":"liezi","text":"目将眇者，先睹秋毫","source":"《列子·说符》","tags":["转化","阴阳相生","归根"],"face":"转化"},
    {"id":"liezi-9","person":"liezi","text":"大哉死乎！君子息焉，小人休焉","source":"《列子·天瑞》","tags":["避世","归根","修身"],"face":"避世"},
    {"id":"liezi-10","person":"liezi","text":"人而无义，唯食而已，是鸡狗也","source":"《列子·说符》","tags":["避世","修身","治国"],"face":"避世"},

    {"id":"wenzi-1","person":"wenzi","text":"道法自然","source":"《文子·道原》","tags":["避世","无为","归根"],"face":"避世"},
    {"id":"wenzi-2","person":"wenzi","text":"食者民之本，民者国之基","source":"《文子·上仁》","tags":["避世","治国","不争"],"face":"避世"},
    {"id":"wenzi-3","person":"wenzi","text":"上无为，下无不为","source":"《文子·自然》","tags":["避世","无为","治国"],"face":"避世"},
    {"id":"wenzi-4","person":"wenzi","text":"先唱者穷之路，后动者达之原","source":"《文子·道原》","tags":["转化","不争","后发先至"],"face":"转化"},
    {"id":"wenzi-5","person":"wenzi","text":"刚强者死之徒，柔弱者生之干","source":"《文子·道原》","tags":["避世","守柔","不争"],"face":"避世"},
    {"id":"wenzi-6","person":"wenzi","text":"夫道者，立于不敢，先于不争","source":"《文子·道原》","tags":["转化","不争","庙算"],"face":"转化"},
    {"id":"wenzi-7","person":"wenzi","text":"天地之道，以德为主","source":"《文子·上德》","tags":["避世","修身","治国"],"face":"避世"},
    {"id":"wenzi-8","person":"wenzi","text":"知者不言，言者不知","source":"《文子·道原》","tags":["转化","无为","诡道"],"face":"转化"},
    {"id":"wenzi-9","person":"wenzi","text":"能成霸王者，必德胜者也","source":"《文子·自然》","tags":["转化","修身","治国"],"face":"转化"},
    {"id":"wenzi-10","person":"wenzi","text":"水激则悍，矢激则远。人激于名，物激于利","source":"《文子·上德》","tags":["转化","任势","修身"],"face":"转化"},

    {"id":"heshanggong-1","person":"heshanggong","text":"养生与治国一理","source":"《老子河上公章句》序意","tags":["转化","无为","修身","治国"],"face":"转化"},
    {"id":"heshanggong-2","person":"heshanggong","text":"谷，养也，人能养神则不死","source":"《老子河上公章句》注第六章","tags":["避世","养生","归根"],"face":"避世"},
    {"id":"heshanggong-3","person":"heshanggong","text":"守一者，万事毕","source":"《老子河上公章句》注第十章","tags":["转化","无为","修身"],"face":"转化"},
    {"id":"heshanggong-4","person":"heshanggong","text":"自然者，道之质也","source":"《老子河上公章句》注第二十五章","tags":["避世","无为","归根"],"face":"避世"},
    {"id":"heshanggong-5","person":"heshanggong","text":"人不畏小威，则大威至","source":"《老子河上公章句》注第七十二章","tags":["转化","不争","权变"],"face":"转化"},
    {"id":"heshanggong-6","person":"heshanggong","text":"以身为国——爱气如爱民，治国如治身","source":"《老子河上公章句》注第十三章","tags":["转化","修身","治国"],"face":"转化"},
    {"id":"heshanggong-7","person":"heshanggong","text":"治身者养神，治国者养民","source":"《老子河上公章句》注","tags":["避世","无为","治国"],"face":"避世"},
    {"id":"heshanggong-8","person":"heshanggong","text":"人法地，法其安静和柔","source":"《老子河上公章句》注第二十五章","tags":["避世","归根","无为"],"face":"避世"},
    {"id":"heshanggong-9","person":"heshanggong","text":"圣人无常心，以百姓心为心","source":"《老子河上公章句》注第四十九章","tags":["转化","不争","治国"],"face":"转化"},
    {"id":"heshanggong-10","person":"heshanggong","text":"治大国若烹小鲜——不挠也","source":"《老子河上公章句》注第六十章","tags":["避世","无为","治国"],"face":"避世"},

    {"id":"fanli-1","person":"fanli","text":"飞鸟尽，良弓藏；狡兔死，走狗烹","source":"《史记·越王勾践世家》","tags":["转化","功成身退","知足"],"face":"转化"},
    {"id":"fanli-2","person":"fanli","text":"与勾践深谋二十余年，竟灭吴","source":"《史记·越王勾践世家》","tags":["进取","任势","修身"],"face":"进取"},
    {"id":"fanli-3","person":"fanli","text":"后则用阴，先则用阳","source":"《越绝书》引范蠡语","tags":["转化","阴阳相生","形势"],"face":"转化"},
    {"id":"fanli-4","person":"fanli","text":"十九年中三致千金，再分散","source":"《史记·货殖列传》","tags":["转化","知足","逍遥"],"face":"转化"},
    {"id":"fanli-5","person":"fanli","text":"旱则资舟，水则资车","source":"《史记·货殖列传》引计然之策","tags":["转化","形势","任势"],"face":"转化"},
    {"id":"fanli-6","person":"fanli","text":"知斗则修备，时用则知物","source":"《史记·货殖列传》引计然之策","tags":["转化","任势","庙算"],"face":"转化"},
    {"id":"fanli-7","person":"fanli","text":"贵出如粪土，贱取如珠玉","source":"《史记·货殖列传》引计然之策","tags":["转化","阴阳相生","权变"],"face":"转化"},
    {"id":"fanli-8","person":"fanli","text":"居官则至卿相，居家则致千金","source":"《史记·货殖列传》","tags":["转化","修身","功成身退"],"face":"转化"},
    {"id":"fanli-9","person":"fanli","text":"从时者，犹救火追亡人也","source":"《国语·越语》引范蠡语","tags":["进取","速决","任势"],"face":"进取"},
    {"id":"fanli-10","person":"fanli","text":"天道盈而不溢，盛而不骄，劳而不矜其功","source":"《国语·越语》引范蠡语","tags":["避世","功成身退","归根"],"face":"避世"},

    {"id":"zhangliang-1","person":"zhangliang","text":"运筹策帷帐之中，决胜于千里之外","source":"《史记·高祖本纪》刘邦评张良","tags":["进取","庙算","无为"],"face":"进取"},
    {"id":"zhangliang-2","person":"zhangliang","text":"愿弃人间事，欲从赤松子游","source":"《史记·留侯世家》","tags":["避世","功成身退","逍遥"],"face":"避世"},
    {"id":"zhangliang-3","person":"zhangliang","text":"借前箸为大王筹之","source":"《史记·留侯世家》","tags":["进取","庙算","任势"],"face":"进取"},
    {"id":"zhangliang-4","person":"zhangliang","text":"沛公殆天授","source":"《史记·留侯世家》","tags":["转化","归根"],"face":"转化"},
    {"id":"zhangliang-5","person":"zhangliang","text":"狙击秦皇帝博浪沙中，误中副车","source":"《史记·留侯世家》","tags":["进取","权变"],"face":"进取"},
    {"id":"zhangliang-6","person":"zhangliang","text":"忍小忿而就大谋","source":"《史记·留侯世家》","tags":["转化","修身","权变"],"face":"转化"},
    {"id":"zhangliang-7","person":"zhangliang","text":"圯桥进履——欲殴之，为其老，强忍，下取履","source":"《史记·留侯世家》","tags":["转化","修身","守柔"],"face":"转化"},
    {"id":"zhangliang-8","person":"zhangliang","text":"为天下者不顾家","source":"《史记·留侯世家》","tags":["进取","修身"],"face":"进取"},
    {"id":"zhangliang-9","person":"zhangliang","text":"今以三寸舌为帝者师，封万户侯，于良足矣","source":"《史记·留侯世家》","tags":["转化","功成身退","知足"],"face":"转化"},
    {"id":"zhangliang-10","person":"zhangliang","text":"人生一世间，如白驹过隙，何至自苦如此乎","source":"《史记·留侯世家》","tags":["避世","归根","逍遥"],"face":"避世"},

    {"id":"zhugeliang-1","person":"zhugeliang","text":"非淡泊无以明志，非宁静无以致远","source":"诸葛亮《诫子书》","tags":["转化","修身","无为","庙算"],"face":"转化"},
    {"id":"zhugeliang-2","person":"zhugeliang","text":"鞠躬尽力，死而后已","source":"诸葛亮《后出师表》","tags":["进取","修身"],"face":"进取"},
    {"id":"zhugeliang-3","person":"zhugeliang","text":"苟全性命于乱世，不求闻达于诸侯","source":"诸葛亮《出师表》","tags":["避世","不争","知足"],"face":"避世"},
    {"id":"zhugeliang-4","person":"zhugeliang","text":"万事俱备，只欠东风","source":"《三国演义》第四十九回","tags":["进取","任势","形势"],"face":"进取"},
    {"id":"zhugeliang-5","person":"zhugeliang","text":"将不可骄，骄则失礼","source":"诸葛亮《将诫》","tags":["转化","修身","守柔"],"face":"转化"},
    {"id":"zhugeliang-6","person":"zhugeliang","text":"静以修身，俭以养德","source":"诸葛亮《诫子书》","tags":["避世","修身","无为"],"face":"避世"},
    {"id":"zhugeliang-7","person":"zhugeliang","text":"夫志当存高远","source":"诸葛亮《诫外生书》","tags":["进取","修身"],"face":"进取"},
    {"id":"zhugeliang-8","person":"zhugeliang","text":"不傲才以骄人，不以宠而作威","source":"诸葛亮《将诫》","tags":["避世","修身","不争"],"face":"避世"},
    {"id":"zhugeliang-9","person":"zhugeliang","text":"夫将者，人之司命，国家之安危所系也","source":"诸葛亮《将苑·假权》","tags":["转化","修身","庙算"],"face":"转化"},
    {"id":"zhugeliang-10","person":"zhugeliang","text":"善将者，不恃强，不怙势","source":"诸葛亮《将苑·将志》","tags":["转化","修身","无为"],"face":"转化"},

    {"id":"liubowen-1","person":"liubowen","text":"金玉其外，败絮其中","source":"刘基《卖柑者言》","tags":["避世","修身"],"face":"避世"},
    {"id":"liubowen-2","person":"liubowen","text":"虎视眈眈，其欲逐逐。彼将搏我，我先搏之","source":"刘基《郁离子·虎兕》","tags":["进取","速决","权变"],"face":"进取"},
    {"id":"liubowen-3","person":"liubowen","text":"夫以力胜人者，力可也，不可久","source":"刘基《郁离子·省敌》","tags":["避世","守柔","形势"],"face":"避世"},
    {"id":"liubowen-4","person":"liubowen","text":"省敌者不使人敌己","source":"刘基《郁离子·省敌》","tags":["转化","不争","庙算"],"face":"转化"},
    {"id":"liubowen-5","person":"liubowen","text":"谗不自来，因疑而来；间不自入，乘隙而入","source":"刘基《郁离子·畏鬼》","tags":["转化","修身","用间"],"face":"转化"},
    {"id":"liubowen-6","person":"liubowen","text":"予岂好辩哉？予不得已也","source":"刘基《郁离子》序","tags":["转化","无为","不争"],"face":"转化"},
    {"id":"liubowen-7","person":"liubowen","text":"人才难得，而用才更难","source":"刘基《郁离子·省敌》","tags":["进取","治国","修身"],"face":"进取"},
    {"id":"liubowen-8","person":"liubowen","text":"舟中之人，尽为敌国。不如守身","source":"刘基《郁离子·射虱》","tags":["转化","修身","庙算"],"face":"转化"},
    {"id":"liubowen-9","person":"liubowen","text":"善扑火者不与之争，避其锐而乘其衰","source":"刘基《郁离子·扑火》","tags":["转化","形势","阴阳相生"],"face":"转化"},
    {"id":"liubowen-10","person":"liubowen","text":"养虎者不以肉饲之，恐其搏噬也","source":"刘基《郁离子·养虎》","tags":["进取","权变","不争"],"face":"进取"},

    {"id":"wangyangming-1","person":"wangyangming","text":"破山中贼易，破心中贼难","source":"王阳明《与杨仕德薛尚谦书》","tags":["转化","修身","归根"],"face":"转化"},
    {"id":"wangyangming-2","person":"wangyangming","text":"知是行之始，行是知之成。知行合一","source":"王阳明《传习录》","tags":["转化","修身","无为"],"face":"转化"},
    {"id":"wangyangming-3","person":"wangyangming","text":"此心不动，随机而动","source":"王阳明《传习录》","tags":["转化","无为","任势"],"face":"转化"},
    {"id":"wangyangming-4","person":"wangyangming","text":"致吾心之良知于事事物物","source":"王阳明《传习录》","tags":["转化","修身","归根"],"face":"转化"},
    {"id":"wangyangming-5","person":"wangyangming","text":"人须在事上磨炼做功夫","source":"王阳明《传习录》","tags":["转化","修身","无为"],"face":"转化"},
    {"id":"wangyangming-6","person":"wangyangming","text":"不动心，则临事便不惧","source":"王阳明《传习录》","tags":["转化","修身","无为"],"face":"转化"},
    {"id":"wangyangming-7","person":"wangyangming","text":"用兵何术？但学问纯笃，养得此心不动，乃术尔","source":"王阳明与学生问答","tags":["转化","修身","无为"],"face":"转化"},
    {"id":"wangyangming-8","person":"wangyangming","text":"定者，心之本体，天理也","source":"王阳明《传习录》","tags":["转化","归根","无为"],"face":"转化"},
    {"id":"wangyangming-9","person":"wangyangming","text":"惟精惟一，允执厥中","source":"王阳明《传习录》引《尚书》","tags":["转化","修身","归根"],"face":"转化"},
    {"id":"wangyangming-10","person":"wangyangming","text":"大人者，以天地万物为一体者也","source":"王阳明《大学问》","tags":["避世","归根","玄同"],"face":"避世"}
  ]
}